# Producción (ej. Render). En desarrollo con dispositivo físico o emulador, usa la IP de tu PC
# en la misma red que Metro (ej. el manifest muestra 192.168.1.86:8082 → API suele ser http://192.168.1.86:8000).
# No uses http://localhost:8000 en el teléfono: localhost es el propio dispositivo.
EXPO_PUBLIC_API_URL=https://tu-api.onrender.com
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OAuth 2.0 Client ID (tipo "Web") en Google Cloud — mismo proyecto que Firebase.
# Firebase Console → Project settings → Your apps → Web, o Google Cloud → Credentials.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# OAuth Client ID tipo "Android" (opcional pero recomendado para Android nativo).
# Si no lo defines, la app usará EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID como fallback.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# OAuth Client ID tipo "iOS" (opcional pero recomendado para iOS nativo).
# Si no lo defines, la app usará EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID como fallback.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
