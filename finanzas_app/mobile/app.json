{
  "expo": {
    "owner": "jaimehernandeze",
    "name": "Finanzas Familiares",
    "slug": "finanzas-familiares",
    "scheme": "com.hernandezValle.finanzas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "platforms": [
      "android",
      "ios"
    ],
    "android": {
      "package": "com.hernandezValle.finanzas"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
