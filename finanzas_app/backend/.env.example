# ============================================================================
# Finanzas App — Variables de entorno completas
# ============================================================================
# Copiar a .env y completar los valores reales.
# NUNCA commitear .env — solo .env.example va al repositorio.
#
# Railway: pegar el contenido en Settings → Variables → RAW Editor.
#          Solo incluir las líneas con valor (sin # ni comentarios).
# ============================================================================

# ── CORE ─────────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

DEBUG=False

# Modo demo: login JWT sin Firebase, datos ficticios con seed_demo.
# Valores reconocidos como «sí»: true, True, 1, yes, on.
DEMO=false

# Meses de datos ficticios al ejecutar seed_demo (1–120, default 15).
# SEED_DEMO_MESES=15

# ── BASE DE DATOS ────────────────────────────────────────────────────────────
# Opción A: URL única (Railway, Render, Supabase, etc.)
# Sin comillas; Supabase suele incluir ?sslmode=require.
DATABASE_URL=

# Opción B: campos separados (docker-compose local). Se ignoran si DATABASE_URL existe.
# DB_NAME=finanzas_db
# DB_USER=finanzas_user
# DB_PASSWORD=
# DB_HOST=localhost

# ── RED / HOSTS ──────────────────────────────────────────────────────────────
# Dominio del backend (Railway, Render, etc.)
ALLOWED_HOSTS=tu-backend.up.railway.app

# URL del frontend (para redirects OAuth y CORS)
FRONTEND_URL=https://tu-frontend.vercel.app

# CORS — orígenes permitidos, separados por coma (scheme + host, sin path ni / final).
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app

# Permitir todos los orígenes (SOLO desarrollo local).
# CORS_ALLOW_ALL_ORIGINS=false

# Forzar SSL redirect en producción (True por defecto cuando DEBUG=False).
# SECURE_SSL_REDIRECT=True

# ── FIREBASE ─────────────────────────────────────────────────────────────────
# Contenido del JSON de servicio en una sola línea.
# Convertir con: cat firebase-service-account.json | python3 -m json.tool --compact
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── ZONA HORARIA ─────────────────────────────────────────────────────────────
TIME_ZONE=America/Santiago

# ── MONEDA ───────────────────────────────────────────────────────────────────
MONEDA_BASE=CLP
MONEDA_SIMBOLO=$
MONEDA_SEPARADOR_MILES=.
MONEDA_SEPARADOR_DECIMALES=,
MONEDA_DECIMALES=0

# ── ASISTENTE FINANCIERO (chat IA) ───────────────────────────────────────────
# POST /api/finanzas/asistente/consulta/ solo responde si HABILITADO=true y hay API key.
# Soporta cualquier endpoint compatible con la API de OpenAI (NVIDIA NIM, Groq, Together, etc.)
ASISTENTE_HABILITADO=false
ASISTENTE_LLM_PROVIDER=nvidia
ASISTENTE_LLM_MODEL=meta/llama-3.1-8b-instruct
ASISTENTE_LLM_API_KEY=
ASISTENTE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
ASISTENTE_MAX_TURNOS_HISTORIAL=8
ASISTENTE_RATE_LIMIT_POR_HORA=30
ASISTENTE_MAX_CHARS_MENSAJE=2000
ASISTENTE_LLM_TIMEOUT_S=60
ASISTENTE_LLM_MAX_TOKENS=1024

# ── CAPTURA — TELEGRAM ───────────────────────────────────────────────────────
CAPTURA_TELEGRAM_HABILITADO=false
CAPTURA_TELEGRAM_BOT_TOKEN=
CAPTURA_TELEGRAM_WEBHOOK_SECRET=

# ── CAPTURA — WHATSAPP (Meta Business API) ───────────────────────────────────
CAPTURA_WHATSAPP_HABILITADO=false
CAPTURA_WHATSAPP_TOKEN=
CAPTURA_WHATSAPP_PHONE_NUMBER_ID=
CAPTURA_WHATSAPP_VERIFY_TOKEN=

# ── CAPTURA — CORREO (intervalo sync) ────────────────────────────────────────
# Mínimo de minutos entre syncs OAuth por usuario.
CAPTURA_EMAIL_INTERVALO_MIN_MINUTOS=5

# ── OAUTH — GOOGLE (Gmail + Drive) ──────────────────────────────────────────
# Credenciales del cliente OAuth tipo «Aplicación web» en Google Cloud Console.
# URIs de redirección autorizados:
#   https://<tu-backend>/api/finanzas/captura/correo/oauth/callback/google/
#   https://<tu-backend>/api/espacios/drive/callback/
# Si usas el mismo cliente para Gmail y Drive, basta con definir GOOGLE_MAIL_*.
# Si GOOGLE_MAIL_* están vacíos, se usan GOOGLE_DRIVE_* como fallback.
GOOGLE_MAIL_OAUTH_CLIENT_ID=
GOOGLE_MAIL_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# ── OAUTH — MICROSOFT (Outlook / Graph) ─────────────────────────────────────
# Azure Portal → App registration → Certificates & secrets.
# Copia el Value del secreto (texto largo), NO el Secret ID (GUID).
# Redirect autorizado:
#   https://<tu-backend>/api/finanzas/captura/correo/oauth/callback/microsoft/
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=consumers

# ── GOOGLE DRIVE — BACKUP GLOBAL ────────────────────────────────────────────
# Solo para backup automático pg_dump → Drive (GitHub Actions / cron).
# No hace falta para OAuth por usuario.
# GOOGLE_DRIVE_BACKUP_FOLDER_ID=
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=

# ── CANDADOS MULTITENANT ─────────────────────────────────────────────────────
# Operaciones globales bloqueadas en producción salvo habilitación explícita.
# Activar SOLO si todas las familias pertenecen al mismo operador.
# ALLOW_GLOBAL_EXPORT=false
# ALLOW_DB_EXPORT=false
# ALLOW_DB_IMPORT=false
# REQUIRE_VERIFIED_EMAIL=false

# ── MÉTRICAS PÚBLICAS ────────────────────────────────────────────────────────
# Habilita el endpoint /api/finanzas/metricas-publicas/ (datos agregados anónimos).
# METRICAS_PUBLICAS_HABILITADAS=false
# Mínimo de usuarios distintos para mostrar desagregaciones (default 10). En demo
# con pocos usuarios puedes bajarlo, p. ej. METRICAS_PUBLICAS_UMBRAL_K=2
# METRICAS_PUBLICAS_UMBRAL_K=10

# ── EXPORT CRON (Google Sheets) ──────────────────────────────────────────────
# Token secreto para el header X-Export-Token (cron / integraciones).
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# EXPORT_SECRET_TOKEN=
