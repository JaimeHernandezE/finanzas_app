# Copiar a .env y completar los valores reales (nunca commitear .env)

DEBUG=False
SECRET_KEY=

# Modo demostración (otra instancia Render + BD aparte). Login JWT en /api/usuarios/demo-login/
DEMO=False

# Base de datos — usar la Internal Database URL de Render
DATABASE_URL=

# Hosts permitidos (dominio de Render)
ALLOWED_HOSTS=tu-app.onrender.com

# CORS — dominio del frontend en Render
CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com

# Firebase — contenido del JSON en una sola línea
# Convertir con: cat firebase-service-account.json | python3 -m json.tool --compact
FIREBASE_SERVICE_ACCOUNT_JSON=

# Zona horaria
TIME_ZONE=America/Santiago

# Moneda
MONEDA_BASE=CLP
MONEDA_SIMBOLO=$
MONEDA_SEPARADOR_MILES=.
MONEDA_SEPARADOR_DECIMALES=,
MONEDA_DECIMALES=0

# --- Backup PostgreSQL a Google Drive (opcional; solo OAuth de usuario / Gmail) ---
# GOOGLE_DRIVE_BACKUP_FOLDER_ID=          # ID carpeta en «Mi unidad» de la cuenta autorizada
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
