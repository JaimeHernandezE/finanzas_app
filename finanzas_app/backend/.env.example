# Copiar a .env y completar los valores reales (nunca commitear .env)

# --- Desarrollo local (docker-compose) ---
# SECRET_KEY: generar con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Credenciales de la BD local (usadas por docker-compose)
DB_NAME=finanzas_db
DB_USER=finanzas_user
DB_PASSWORD=

DEBUG=False

# Modo demostración (otra instancia Render + BD aparte). Login JWT en /api/usuarios/demo-login/
# Valores reconocidos como «sí»: true, True, 1, yes, on (build.sh seed_demo usa la misma regla).
DEMO=False

# Opcional: al ejecutar manage.py seed_demo, meses de historia (1–120). Por defecto 15. Útil en CI (p. ej. SEED_DEMO_MESES=6).
# SEED_DEMO_MESES=15

# Base de datos — una sola URL (Render Internal/External, Supabase URI desde Settings → Database, etc.).
# Sin comillas en el valor; Supabase suele incluir ?sslmode=require. ParseError: revisar pegado y encoding de la contraseña.
# Supabase: desde Render suele hacer falta la URI del pooler (Session), no solo db.<ref>.supabase.co (IPv6 → Network unreachable).
# Ejemplo directo (otros hosts): postgresql://postgres:<CONTRASEÑA>@db.<ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Hosts permitidos (dominio del proveedor: Railway, Render, etc.)
ALLOWED_HOSTS=tu-backend.up.railway.app

# CORS — origen del navegador (scheme + host, sin path). Ej.: https://finanzas-app-demo-static.onrender.com
# Varias URLs separadas por coma. Debe incluir el Static Site demo si el API es otro subdominio.
# El front normaliza VITE_API_URL (quita / final); aquí el origen no lleva barra al final.
CORS_ALLOWED_ORIGINS=https://tu-frontend.onrender.com

# Firebase — contenido del JSON en una sola línea
# Convertir con: cat firebase-service-account.json | python3 -m json.tool --compact
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Asistente financiero (Etapa B: chat + NVIDIA NIM) ---
# POST /api/finanzas/asistente/consulta/ solo responde si HABILITADO=true y hay API key.
# ASISTENTE_HABILITADO=false
# ASISTENTE_LLM_PROVIDER=nvidia
# ASISTENTE_LLM_MODEL=meta/llama-3.3-70b-instruct
# ASISTENTE_LLM_API_KEY=nvapi-...
# ASISTENTE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# ASISTENTE_MAX_TURNOS_HISTORIAL=8
# ASISTENTE_RATE_LIMIT_POR_HORA=30
# ASISTENTE_MAX_CHARS_MENSAJE=2000

# Zona horaria
TIME_ZONE=America/Santiago

# Moneda
MONEDA_BASE=CLP
MONEDA_SIMBOLO=$
MONEDA_SEPARADOR_MILES=.
MONEDA_SEPARADOR_DECIMALES=,
MONEDA_DECIMALES=0

# --- Candados multitenant (Fase 0 del plan) ---
# Estas operaciones tocan datos de TODAS las familias de la instancia. En producción
# quedan bloqueadas salvo habilitación explícita. Actívalas SOLO mientras todas las
# familias pertenezcan al mismo operador (instancia personal/familiar única).
# ALLOW_GLOBAL_EXPORT=true    # export a Google Sheets vía cron (X-Export-Token); sin botón en la app
# ALLOW_DB_EXPORT=true        # descarga de dump y subida de respaldo a Drive
# ALLOW_DB_IMPORT=true        # restauración de BD completa (ventanas controladas)
# REQUIRE_VERIFIED_EMAIL=true # exigir email verificado en Firebase para registrarse (activar antes de abrir registro a terceros)

# --- Google Drive OAuth (cliente tipo «Aplicación web») ---
# Usado por: (1) OAuth por usuario «Conectar Google Drive» y (2) backup global pg_dump.
# En Google Cloud → Credenciales → URIs de redirección autorizados, añade el callback del API:
#   https://<tu-backend>/api/espacios/drive/callback/
#   http://localhost:8000/api/espacios/drive/callback/
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
# --- Solo backup global / GitHub Actions (no hace falta para OAuth por usuario) ---
# GOOGLE_DRIVE_BACKUP_FOLDER_ID=          # ID carpeta en «Mi unidad» de la cuenta autorizada
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
